{
  "name": "deposito-seguro",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "ts:check": "tsc",
    "analyze": "echo '=== 1. Checking Expo Integrity ===' && npx expo-doctor && echo '=== 2. Running TypeScript Structural Check ===' && npx tsc --noEmit",
